# =============================================================================
# vintage-market · Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle alle Werte aus.
# NIEMALS .env.local committen!
# =============================================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=vintage_user
POSTGRES_PASSWORD=SicheresPasswort123!
POSTGRES_DB=vintage_market
# Für lokale Entwicklung (db = Docker-Service-Name, localhost für direkt)
DATABASE_URL=postgresql://vintage_user:SicheresPasswort123!@localhost:5432/vintage_market
# Für Docker Compose (app-Container → db-Container)
# DATABASE_URL=postgresql://vintage_user:SicheresPasswort123!@db:5432/vintage_market

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generieren: openssl rand -base64 32
NEXTAUTH_SECRET=HIER_ZUFAELLIGEN_STRING_EINFUEGEN_MIN_32_ZEICHEN
NEXTAUTH_URL=https://galeriedutemps.kz
# Für lokale Entwicklung:
# NEXTAUTH_URL=http://localhost:3000

# ─── DeepSeek KI ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-deepseek-HIER_API_KEY_EINFUEGEN

# ─── Email-Provider (Switcher) ───────────────────────────────────────────────
# Welcher Provider aktiv ist: "resend" oder "brevo". Default ist brevo
# (Backwards-Compat). Beide Provider können konfiguriert sein — der Switcher
# wählt zur Laufzeit aus.
EMAIL_PROVIDER=resend
# Gemeinsame Sender-Adresse (Resend braucht verifizierte Domain!)
EMAIL_FROM=noreply@galeriedutemps.kz
EMAIL_FROM_NAME=Galerie du Temps

# ─── Resend ──────────────────────────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
# Vor Nutzung: Domain galeriedutemps.kz in Resend verifizieren (3 DNS-Records)
RESEND_API_KEY=re_HIER_RESEND_KEY_EINFUEGEN

# ─── Brevo (Fallback / Alternative) ──────────────────────────────────────────
BREVO_API_KEY=xkeysib-HIER_API_KEY_EINFUEGEN
BREVO_SENDER_EMAIL=noreply@galeriedutemps.kz
BREVO_SENDER_NAME=Galerie du Temps

# ─── Redis (Upstash) — Cache, Rate-Limit, Sessions, Queue ───────────────────
# Upstash: https://console.upstash.com/redis — "Create Database" → TCP-URL
# kopieren (rediss://default:***@***-***.upstash.io:6379)
# Für lokale Entwicklung kann auch redis://localhost:6379 verwendet werden.
# Wenn nicht gesetzt: Cache off, Rate-Limit fällt auf In-Memory zurück.
REDIS_URL=rediss://default:DEIN_TOKEN@DEIN-ENDPOINT.upstash.io:6379

# ─── N8N (Workflow-E-Mails & Automatisierungen) ───────────────────────────────
N8N_HOST=n8n.galeriedutemps.kz
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=SicheresN8nPasswort456!
# Webhook-URLs (nach N8N-Setup eintragen)
N8N_KONTAKT_WEBHOOK_URL=https://n8n.galeriedutemps.kz/webhook/kontakt
N8N_LAGERBESTAND_WEBHOOK_URL=https://n8n.galeriedutemps.kz/webhook/lagerbestand

# ─── Uploads / Storage ────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
NEXT_PUBLIC_UPLOAD_URL=https://galeriedutemps.kz/uploads
# Optional: S3-kompatibel (z.B. Hetzner Object Storage)
# S3_ENDPOINT=https://nbg1.your-objectstorage.com
# S3_ACCESS_KEY=HIER_ACCESS_KEY
# S3_SECRET_KEY=HIER_SECRET_KEY
# S3_BUCKET=vintage-market-uploads
# S3_REGION=eu-central-1

# ─── Affiliate-System ────────────────────────────────────────────────────────
# Verschlüsselungs-Key für IBAN (pgcrypto pgp_sym_encrypt)
# Generieren: openssl rand -base64 32
IBAN_ENCRYPTION_KEY=HIER_IBAN_KEY_MIN_32_ZEICHEN

# Salt für IP/User-Agent Hashing (DSGVO-Pseudonymisierung)
REFERRAL_CODE_SALT=HIER_SALT_MIN_16_ZEICHEN

# Cleanup-Intervall für alte Affiliate-Klicks (Default 90 Tage)
# AFFILIATE_CLEANUP_TAGE=90

# ─── Stripe (Pflicht für Checkout, ab Phase 10a) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_HIER_EINFUEGEN              # oder sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_HIER_EINFUEGEN
STRIPE_WEBHOOK_SECRET=whsec_HIER_EINFUEGEN            # via `stripe listen` oder Dashboard

# ─── Stripe Connect (optional, für automatische Affiliate-Auszahlungen) ─────
# STRIPE_CONNECT_CLIENT_ID=ca_HIER_EINFUEGEN
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Kasachstan-Lokalisierung (Phase 11) ─────────────────────────────────────
NEXT_PUBLIC_DEFAULT_COUNTRY=KZ
NEXT_PUBLIC_DEFAULT_LANGUAGE=ru           # ru | kz | en | de
NEXT_PUBLIC_DEFAULT_CURRENCY=KZT
NEXT_PUBLIC_VAT_DEFAULT=12                # KZ: 12, DE: 19, AT: 20

# ─── Kaspi.kz Pay (Hauptzahlungsmethode für KZ) ──────────────────────────────
# Setup-Anleitung: src/lib/payment/kaspi.ts
# KASPI_MERCHANT_ID=...
# KASPI_TERMINAL_ID=...
# KASPI_API_KEY=...
# KASPI_API_BASE=https://kaspi.kz/api/v2  # test: https://test.kaspi.kz/api/v2
# KASPI_WEBHOOK_SECRET=...

# ─── Sentry (Error-Tracking) ──────────────────────────────────────────────────
# Setup: https://sentry.io → Create Project (Next.js) → DSN kopieren
# DSN ist NICHT geheim (Sentry rate-limited pro Project).
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.de.sentry.io/YYY
SENTRY_DSN=https://xxx@oXXX.ingest.de.sentry.io/YYY
# Org + Project slugs (für Source-Map-Upload bei jedem Build)
SENTRY_ORG=
SENTRY_PROJECT=
# Auth-Token (Build-Time, GEHEIM). Sentry → Settings → Auth Tokens.
# Scopes: project:releases + org:read
SENTRY_AUTH_TOKEN=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://galeriedutemps.kz
NODE_ENV=production
